# model (required) — mini tier is the default: extraction-only workload
MODEL_ANALYST=openai:gpt-5.4-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# pipeline
JOB_FANOUT_CONCURRENCY=3

# agent service (chat bridge) — MODEL_CHAT falls back to MODEL_ANALYST
MODEL_CHAT=
JOBMATCHER_API_URL=http://localhost:8000
AGENT_UPLOAD_DIR=
AGENT_PORT=8006

# telemetry — fill a block to enable that backend
OBSERVABILITY_SINK=json
TELEMETRY_RECORD_IO=false

OPENOBSERVE_URL=
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=job_matcher
OPENOBSERVE_USER=
OPENOBSERVE_PASSWORD=

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=

ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=job-matcher
