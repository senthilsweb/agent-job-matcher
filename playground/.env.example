# Backend base URL used by the server-side /api/analyze proxy route
# (app/api/analyze/route.ts). Never read client-side — the browser only
# ever talks to this Next.js app's own origin.
#
# Local dev: the backend running on your machine.
# docker-compose: the compose network's service name, e.g. http://api:8000.
API_URL=http://localhost:8000
